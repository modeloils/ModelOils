<script src="https://cdnjs.cloudflare.com/ajax/libs/js-sha256/0.9.0/sha256.min.js"></script>
<script>

    function generateEventId() {
        return 'fbid' + Date.now();
    }
    let current_url = window.location.href;

    function getCookie(name) {
        let match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return match ? match[2] : '';
    }
    let fbp = getCookie('_fbp') || '';
    let fbc = getCookie('_fbc') || '';

    function hashData(data) {
        return sha256(data.toLowerCase().trim());
    }

    async function sendFacebookEvents() {
        let eventId = generateEventId();
        let userIp = "";

        try {
            let response = await fetch('https://api64.ipify.org?format=json');
            let data = await response.json();
            userIp = data.ip;
        } catch (error) {
            console.error("Error getting IP:", error);
        }

        let email = "user@example.com";
        let phone = "+1234567890";
        let hashedEmail = hashData(email);
        let hashedPhone = hashData(phone);

        let eventData = {
            data: [
                {
                    event_name: "PageView",
                    event_time: Math.floor(Date.now() / 1000),
                    event_id: eventId,
                    action_source: "website",
                    event_source_url: current_url,
                    user_data: {
                        client_ip_address: userIp,
                        client_user_agent: navigator.userAgent,
                        fbc: fbc,
                        fbp: fbp,
                        fn: "",
                        ph: hashedPhone,
                        em: hashedEmail
                    }
                }
            ],
            test_event_code: "TEST50581"
        };


        if (window.location.pathname.includes("thanks.html")) {
            eventData.data.push({
                event_name: "Lead",
                event_time: Math.floor(Date.now() / 1000),
                event_id: eventId,
                action_source: "website",
                event_source_url: current_url,
                user_data: {
                    client_ip_address: userIp,
                    client_user_agent: navigator.userAgent,
                    fbc: fbc,
                    fbp: fbp,
                    fn: "",
                    ph: hashedPhone,
                    em: hashedEmail
                }
            });
        }

        let fb_pixel_id = "798114616957381";
        let access_token = "EAAFL735HKCEBOz2FXcn3niMxQ9NvRI8fyFWb8hoZBa0nJ3RhZB9e2z5O0OpwshhyAjmbqGjkQ7ZCgn4h9aajaJ3RsX6abPLxqt0cX433zG9uCt37jchzwmNC5cJG868MPjEx6qN2p1XiMMO4bTxDMaR3lQcLOMllZCPKbuNNUUjpiU8TvbB3UegnnJaiwZBboZBQZDZD";

        fetch(`https://graph.facebook.com/v14.0/${fb_pixel_id}/events?access_token=${access_token}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(eventData)
        })
            .then(response => response.json())
            .then(data => console.log("Facebook API Response:", data))
            .catch(error => console.error("Error sending Facebook API:", error));
    }

    sendFacebookEvents();
</script>



<script src="libs/jquery/dist/jquery.min.js"></script>
<script src="libs/swiper/swiper.js"></script>
<script src="js/common.js?v1"></script>


</body>
